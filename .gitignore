# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.pod
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
conda-meta/

# ── OS / editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── MLflow ────────────────────────────────────────────────
#mlruns/
#mlartifacts/

# ── DVC internal cache (never commit) ────────────────────
.dvc/cache/
.dvc/tmp/

# Allow DVC config and remote settings (tracked by Git)
!.dvc/config
!.dvc/.gitignore

# ── Model artifacts ───────────────────────────────────────
#models/
#checkpoints/
#artifacts/

# ── Database files ────────────────────────────────────────
#db/*.db
#*.sqlite
#*.db

# ── Reports (generated, tracked by DVC) ──────────────────
reports/

# ── Misc ─────────────────────────────────────────────────
#*.csv
#*.parquet
#*.h5
#*.pkl
#*.joblib
#*.pt
#*.pth
#*.onnx
*.tar
*.zip

# =============================
# Portfolio exceptions for lightweight data outputs
# =============================

# Keep summary/report folders visible in GitHub
!data/analytics/
!data/analytics/quality/
!data/analytics/quality/**

!data/processed/
!data/processed/metadata/
!data/processed/metadata/**

!data/processed/evaluation_reports/
!data/processed/evaluation_reports/**

!data/processed/validation_reports/
!data/processed/validation_reports/**

# Keep DVC metafiles tracked
!data/raw.dvc
!data/processed/cleaned.dvc
!data/processed/evaluation_reports.dvc
!data/processed/validation_reports.dvc

# Keep DVC config tracked
#!.dvc/config
#!.dvc/.gitignore

# Explicitly keep large data folders out of Git
data/external/mit_indoor/Images/
data/external/mit_indoor/indoorCVPR_09.tar
data/raw/mit_indoor_subset/
data/processed/cleaned/
data/versions/dvc_remote/

# Ignore junk inside visible data folders
data/**/*.crc
data/**/.DS_Store
data/**/.ipynb_checkpoints/

