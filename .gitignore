# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.pyd
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
conda-meta/

# ── OS / editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── MLflow ────────────────────────────────────────────────
mlruns/
mlartifacts/

# ── DVC internal cache (never commit) ────────────────────
.dvc/cache/
.dvc/tmp/

# Allow DVC config and remote settings (tracked by Git)
!.dvc/config
!.dvc/.gitignore

# ── Model artifacts ───────────────────────────────────────
models/
checkpoints/
artifacts/

# ── Database files ────────────────────────────────────────
db/*.db
*.sqlite
*.db

# ── Reports (generated, tracked by DVC) ──────────────────
reports/

# ── Misc ─────────────────────────────────────────────────
*.csv
*.parquet
*.h5
*.pkl
*.joblib
*.pt
*.pth
*.onnx
