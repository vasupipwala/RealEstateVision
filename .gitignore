# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.pod
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
conda-meta/

# ── OS / editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── MLflow ────────────────────────────────────────────────
!mlruns/
!mlruns/**
!mlartifacts/

# ── DVC internals ─────────────────────────────────────────
.dvc/cache/
.dvc/tmp/

# Keep DVC project config in Git
!.dvc/config
!.dvc/.gitignore

# ── Model artifacts ───────────────────────────────────────
#checkpoints/
#artifacts/
#models/

# Explicitly allow model artifacts in Git
!models/
!models/**
!checkpoints/
!checkpoints/**
!*.pt
!*.pth

# ── Local databases ───────────────────────────────────────
!db/
!db/**
!db/*.db
!*.sqlite
!*.db

# ── Large binary artifacts ────────────────────────────────
*.parquet
*.h5
*.pkl
*.joblib
#*.pth
*.onnx
*.tar
*.zip

# ── Reports generated outside Git by default ──────────────
reports/

# ── Data policy ───────────────────────────────────────────
# Never track the whole data tree directly in Git
data/**

# But keep lightweight report/metadata folders visible in Git when present
!data/
!data/processed/
!data/processed/metadata/
!data/processed/metadata/**
!data/processed/validation_reports/
!data/processed/validation_reports/**
!data/processed/evaluation_reports/
!data/processed/evaluation_reports/**
!data/analytics/
!data/analytics/**

# Keep DVC metafiles in Git
!data/external.dvc
!data/raw.dvc
!data/processed/cleaned.dvc
!data/processed/metadata.dvc
!data/processed/validation_reports.dvc
!data/processed/evaluation_reports.dvc
!data/analytics.dvc

# Explicitly forbid versions folder everywhere
data/versions/

# Ignore junk inside visible data folders
data/**/*.crc
data/**/.DS_Store
data/**/.ipynb_checkpoints/


data/versions/
.dvc/cache/
